{
    "name": "tui",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "pnpm typecheck && nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "typecheck": "nuxt typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "exec prettier . --write",
        "test": "vitest run --project unit --project nuxt",
        "test:unit": "vitest run --project unit",
        "test:e2e": "vitest run --project e2e",
        "test:coverage": "vitest run --project unit --project nuxt --coverage"
    },
    "dependencies": {
        "@bbob/html": "4.3.1",
        "@bbob/plugin-helper": "4.3.1",
        "@bbob/preset-html5": "4.3.1",
        "@nuxt/eslint": "1.15.2",
        "@nuxt/image": "2.0.0",
        "@nuxt/ui": "4.7.1",
        "@seald-io/nedb": "4.1.2",
        "consola": "3.4.2",
        "create-torrent": "6.1.0",
        "eslint": "10.3.0",
        "nuxt": "4.4.5",
        "parse-torrent": "11.0.19",
        "tailwindcss": "4.3.0",
        "vue": "3.5.34",
        "vue-router": "5.0.7",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@bbob/types": "4.3.1",
        "@iconify-json/heroicons": "1.2.3",
        "@iconify-json/lucide": "1.2.107",
        "@iconify-json/material-symbols": "1.2.71",
        "@iconify-json/qlementine-icons": "1.2.15",
        "@nuxt/test-utils": "4.0.3",
        "@testing-library/user-event": "14.6.1",
        "@testing-library/vue": "8.1.0",
        "@types/create-torrent": "6.1.1",
        "@types/parse-torrent": "5.8.8",
        "@vitest/coverage-istanbul": "4.1.6",
        "@vitest/coverage-v8": "4.1.6",
        "@vue/test-utils": "2.4.10",
        "eslint-config-prettier": "10.1.8",
        "happy-dom": "20.9.0",
        "playwright-core": "1.60.0",
        "pnpm": "11.1.1",
        "prettier": "3.8.3",
        "typescript": "6.0.3",
        "vitest": "4.1.6",
        "vue-tsc": "3.2.8"
    },
    "overrides": {
        "vite-plugin-checker": "0.13.0"
    }
}
