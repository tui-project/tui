{
    "name": "tui",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "pnpm typecheck && nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "typecheck": "nuxt typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "exec prettier . --write",
        "test": "vitest run",
        "test:unit": "vitest run --project unit",
        "test:e2e": "vitest run --project e2e",
        "test:coverage": "vitest run --project unit --project nuxt --coverage"
    },
    "dependencies": {
        "@nuxt/eslint": "1.15.2",
        "@nuxt/image": "2.0.0",
        "@nuxt/ui": "4.7.0",
        "@seald-io/nedb": "4.1.2",
        "consola": "3.4.2",
        "eslint": "10.2.1",
        "nuxt": "4.4.2",
        "pnpm": "^10.33.2",
        "tailwindcss": "4.2.4",
        "vue": "3.5.33",
        "vue-router": "5.0.6",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@nuxt/test-utils": "4.0.2",
        "@testing-library/user-event": "14.6.1",
        "@testing-library/vue": "8.1.0",
        "@vitest/coverage-v8": "4.1.5",
        "@vue/test-utils": "2.4.8",
        "eslint-config-prettier": "10.1.8",
        "happy-dom": "20.9.0",
        "playwright-core": "1.59.1",
        "prettier": "3.8.3",
        "typescript": "6.0.3",
        "vitest": "4.1.5",
        "vue-tsc": "3.2.7"
    },
    "overrides": {
        "vite-plugin-checker": "0.13.0"
    }
}
